# Локальный стенд art-api (см. docker-compose.yml). Скопируй в .env и
# поправь при необходимости — значения ниже совпадают со значениями по
# умолчанию в docker-compose.yml (через ${VAR:-default} синтаксис), .env
# нужен только если хочешь их переопределить.

POSTGRES_USER=art_api
POSTGRES_PASSWORD=art_api_local_dev
POSTGRES_DB=art_api

# Порт Postgres на хосте (для psql/любого клиента с твоей машины).
# Сам art-api всегда обращается к postgres:5432 внутри docker-сети,
# этот порт его не касается.
POSTGRES_PORT=5432

# Порт, на котором art-api доступен с хоста.
ART_API_PORT=8080

# DATABASE_URL для art-api собирается автоматически в docker-compose.yml
# из переменных выше. Эта переменная нужна только если запускаешь art-api
# ИЛИ artkeys локально без docker-compose, напрямую через `go run`:
#
#   export DATABASE_URL="postgres://art_api:art_api_local_dev@localhost:5432/art_api?sslmode=disable"
#   go run ./cmd/art-api
#   go run ./cmd/artkeys create --label "my key"
#
# Credentials не передаются как флаг командной строки осознанно — см.
# комментарий в cmd/art-api/main.go.
